# =============================================================================
# TestAI Platform — Comprehensive .gitignore
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnp.cjs
backend/node_modules/

# ── Next.js / Build Output ───────────────────────────────────────────────────
.next/
out/
build/
dist/
.vercel/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend.log
uvicorn.log

# ── Environment Files ────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging.local
.env.*.local
# NOTE: .env.example is intentionally tracked as a template

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
.project
.classpath
.settings/

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store*

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
venv/
.venv/
env/
backend/venv/
backend/.venv/
*.so
.pytest_cache/
htmlcov/
.coverage
.coverage.*
.coverage.*.*

# ── Test & Coverage Output ───────────────────────────────────────────────────
test-results/
coverage/
junit.xml
jest-junit/
*.coverage

# ── Database / Runtime Data Files ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm
harness_data.db/

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Cache & Temp Files ───────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.cache/
.turbo/
*.tgz
.tmp
.temp
.pytest_cache/

# ── Tool-Specific Config (local / per-developer) ─────────────────────────────
.openclaude/
.codegraph/
.testai/skills/
.testai/agents/

# ── Agent Workspace (generated results only) ─────────────────────────────────
agent_workspace/results/
agent_workspace/knowledge-graphs/
backend/agent_workspace/

# ── Project-Specific Scratch / Runtime Directories ───────────────────────────
data/
in_progess/
plans/
reference/
docs/research/

# ── Lock files (generated, not authored) ─────────────────────────────────────
uv.lock

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.orig
*.tmp
*.temp
~$*
*.docx
backend/check_keys.py
backend/verify_llm.py
backend/fix_providers.py
