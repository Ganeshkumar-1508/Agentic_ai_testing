        <mxCell id="d-w1" value="Worker A (depth=2)&lt;br&gt;role=leaf" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=8;fontColor=#047857;" vertex="1" parent="1">
