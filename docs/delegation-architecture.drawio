        <mxCell id="ta-l3" value="L3: Orchestrator exception — retains delegate_task" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#f59e0b;fontSize=8;fontColor=#92400e;" vertex="1" parent="1">
