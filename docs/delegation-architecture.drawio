        </mxCell>
        <mxCell id="m3-delegate" value="delegate_task(background=True)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m3-bg">
