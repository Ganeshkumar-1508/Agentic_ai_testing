        </mxCell>
        <mxCell id="m3-returns" value="Returns subagent_id immediately" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m3-bg">
          <mxGeometry x="20" y="110" width="100" height="25" as="geometry" />
        </mxCell>

        <mxCell id="m3-bg-worker" value="Background Worker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=8;fontColor=#047857;" vertex="1" parent="m3-bg">
          <mxGeometry x="300" y="35" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m3-bg-desc" value="Runs on daemon executor&lt;br&gt;Re-enters via completion queue" style="text;html=1;fontSize=6;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="m3-bg">
          <mxGeometry x="300" y="70" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m3-note" value="Parent does NOT wait — child result re-enters conversation asynchronously" style="text;html=1;fontSize=7;align=center;fillColor=none;strokeColor=none;fontColor=#475569;" vertex="1" parent="m3-bg">
          <mxGeometry x="20" y="150" width="560" height="20" as="geometry" />
        </mxCell>

