          <mxGeometry x="900" y="400" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="d-w3" value="Worker C (depth=2)&lt;br&gt;role=leaf" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=8;fontColor=#047857;" vertex="1" parent="1">
          <mxGeometry x="1050" y="400" width="130" height="30" as="geometry" />
        </mxCell>

        <mxCell id="d-leaf-desc" value="No delegate_task&lt;br&gt;No clarify, memory, send_message&lt;br&gt;Restricted toolset" style="text;html=1;fontSize=6;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="1">
          <mxGeometry x="750" y="440" width="430" height="35" as="geometry" />
        </mxCell>

        <mxCell id="d-limit" value="max_spawn_depth = 2 (default)&lt;br&gt;Depth 3+ is rejected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#f59e0b;fontSize=8;fontColor=#92400e;" vertex="1" parent="1">
          <mxGeometry x="750" y="500" width="430" height="35" as="geometry" />
        </mxCell>
        <mxCell id="d-limit-desc" value="Configurable via delegation.max_spawn_depth.&lt;br&gt;N levels multiply API cost — default 2 is safe." style="text;html=1;fontSize=7;align=center;fillColor=none;strokeColor=none;fontColor=#92400e;" vertex="1" parent="d-limit">
          <mxGeometry x="5" y="16" width="420" height="18" as="geometry" />
        </mxCell>

        <mxCell id="d-max-children" value="max_concurrent_children = 3 (default)&lt;br&gt;Batch with 4+ tasks is rejected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#f59e0b;fontSize=8;fontColor=#92400e;" vertex="1" parent="1">
