<mxfile>
  <diagram name="Agent Delegation Architecture" id="delegation-arch">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t" value="TestAI — Agent Delegation &amp; Orchestration" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#10b981;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="l-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="l-title" value="Legend" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="50" y="15" width="220" height="16" as="geometry" />
        </mxCell>
        <mxCell id="l-root" value="Root / Orchestrator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#f472b6;fontSize=8;fontColor=#9d174d;" vertex="1" parent="1">
          <mxGeometry x="55" y="35" width="80" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l-coord" value="Coordinator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#818cf8;fontSize=8;fontColor=#3730a3;" vertex="1" parent="1">
          <mxGeometry x="55" y="57" width="80" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l-worker" value="Leaf Worker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=8;fontColor=#047857;" vertex="1" parent="1">
          <mxGeometry x="55" y="79" width="80" height="18" as="geometry" />
        </mxCell>
        <mxCell id="l-sync" value="Sync (blocking)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#f59e0b;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry x="0" y="0" relative="1" as="geometry">
            <mxPoint x="150" y="44" />
            <mxPoint x="210" y="44" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l-fanout" value="Fan-Out (parallel)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8b5cf6;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry x="0" y="0" relative="1" as="geometry">
            <mxPoint x="150" y="66" />
            <mxPoint x="210" y="66" />
          </mxGeometry>
        </mxCell>
        <mxCell id="l-bg" value="Background" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#94a3b8;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry x="0" y="0" relative="1" as="geometry">
            <mxPoint x="150" y="88" />
            <mxPoint x="210" y="88" />
          </mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- FLOW: OVERVIEW -->
        <!-- ============================================ -->
        <mxCell id="section-overview" value="Delegation Tree — Three Modes" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="60" y="190" width="380" height="22" as="geometry" />
        </mxCell>

        <!-- MODE 1: Sync (blocking) -->
        <mxCell id="m1-bg" value="MODE 1: Sync (blocking inline call)" style="swimlane;startSize=24;horizontal=0;fillColor=#fef3c7;strokeColor=#f59e0b;html=1;fontSize=10;fontStyle=1;fontColor=#92400e;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="380" height="200" as="geometry" />
        </mxCell>

        <mxCell id="m1-root" value="Root Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#f472b6;fontSize=9;fontColor=#9d174d;fontStyle=1;" vertex="1" parent="m1-bg">
          <mxGeometry x="20" y="35" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m1-delegate" value="delegate_task(goal)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m1-bg">
          <mxGeometry x="20" y="75" width="100" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m1-child" value="Subagent (leaf)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=9;fontColor=#047857;" vertex="1" parent="m1-bg">
          <mxGeometry x="240" y="35" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m1-child-desc" value="Isolated conversation&lt;br&gt;Restricted tools" style="text;html=1;fontSize=7;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="m1-bg">
          <mxGeometry x="240" y="70" width="120" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m1-child2" value="..." style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="m1-bg">
          <mxGeometry x="135" y="35" width="40" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m1-return" value="Returns summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m1-bg">
          <mxGeometry x="240" y="105" width="120" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m1-parent-resumes" value="Parent resumes loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m1-bg">
          <mxGeometry x="20" y="110" width="100" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m1-note" value="Parent blocks until child finishes" style="text;html=1;fontSize=7;align=center;fillColor=none;strokeColor=none;fontColor=#92400e;" vertex="1" parent="m1-bg">
          <mxGeometry x="20" y="145" width="340" height="20" as="geometry" />
        </mxCell>

        <!-- MODE 2: Fan-Out (parallel) -->
        <mxCell id="m2-bg" value="MODE 2: Fan-Out (parallel spawn + collect_results)" style="swimlane;startSize=24;horizontal=0;fillColor=#f3e8ff;strokeColor=#c084fc;html=1;fontSize=10;fontStyle=1;fontColor=#6b21a8;" vertex="1" parent="1">
          <mxGeometry x="60" y="440" width="600" height="240" as="geometry" />
        </mxCell>

        <mxCell id="m2-root" value="Root Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#f472b6;fontSize=9;fontColor=#9d174d;fontStyle=1;" vertex="1" parent="m2-bg">
          <mxGeometry x="20" y="35" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m2-delegate" value="delegate_task(tasks=[...])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m2-bg">
          <mxGeometry x="20" y="75" width="100" height="25" as="geometry" />
        </mxCell>

        <mxCell id="m2-c1" value="Worker 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=8;fontColor=#047857;" vertex="1" parent="m2-bg">
          <mxGeometry x="200" y="35" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m2-c2" value="Worker 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=8;fontColor=#047857;" vertex="1" parent="m2-bg">
          <mxGeometry x="330" y="35" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="m2-c3" value="Worker N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#34d399;fontSize=8;fontColor=#047857;" vertex="1" parent="m2-bg">
          <mxGeometry x="460" y="35" width="100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="m2-c1-desc" value="ThreadPoolExecutor&lt;br&gt;concurrent.futures" style="text;html=1;fontSize=6;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="m2-bg">
          <mxGeometry x="200" y="70" width="100" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m2-c2-desc" value="Parallel execution" style="text;html=1;fontSize=6;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="m2-bg">
          <mxGeometry x="330" y="70" width="100" height="22" as="geometry" />
        </mxCell>
        <mxCell id="m2-c3-desc" value="Max=3 concurrent" style="text;html=1;fontSize=6;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="m2-bg">
          <mxGeometry x="460" y="70" width="100" height="22" as="geometry" />
        </mxCell>

        <mxCell id="m2-collect" value="collect_results()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m2-bg">
          <mxGeometry x="20" y="115" width="100" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m2-agg" value="Aggregates results array" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d1d5db;fontSize=7;fontColor=#374151;" vertex="1" parent="m2-bg">
          <mxGeometry x="280" y="115" width="140" height="25" as="geometry" />
        </mxCell>
        <mxCell id="m2-note" value="Waits for all children, collects results sorted by task_index" style="text;html=1;fontSize=7;align=center;fillColor=none;strokeColor=none;fontColor=#6b21a8;" vertex="1" parent="m2-bg">
          <mxGeometry x="20" y="155" width="560" height="20" as="geometry" />
        </mxCell>

        <!-- MODE 3: Background -->
        <mxCell id="m3-bg" value="MODE 3: Background (fire-and-steer with subagent_id)" style="swimlane;startSize=24;horizontal=0;fillColor=#f1f5f9;strokeColor=#94a3b8;html=1;fontSize=10;fontStyle=1;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="600" height="200" as="geometry" />
        </mxCell>

        <mxCell id="m3-root" value="Root Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#f472b6;fontSize=9;fontColor=#9d174d;fontStyle=1;" vertex="1" parent="m3-bg">
