        </mxCell>
        <mxCell id="ta-l3-desc" value="Coordinator/orchestrator role keeps the spawn capability" style="text;html=1;fontSize=7;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="ta-l3">
