        <mxCell id="ta-l2-desc" value="delegate_task, clarify, memory, send_message — blocked" style="text;html=1;fontSize=7;align=center;fillColor=none;strokeColor=none;fontColor=#94a3b8;" vertex="1" parent="ta-l2">
