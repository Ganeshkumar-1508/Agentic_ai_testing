        <!-- Blocklist → Subprocess -->
        <mxCell id="e-bl-sub" value="strips blocked vars" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#ef4444;strokeWidth=2;" edge="1" parent="1" source="bl-bg" target="subproc">
