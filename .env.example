# =============================================================================
# TestAI Platform - Frontend (Next.js) Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# These are publicly exposed to the browser (NEXT_PUBLIC_ prefix).
# Never put secret keys here.
# =============================================================================

# Backend API URL (FastAPI server)
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8001
# Docker Compose: http://backend:8000
# Production: https://api.yourdomain.com

# WebSocket URL (for real-time agent updates)
NEXT_PUBLIC_WS_URL=ws://localhost:8001
# Docker Compose: ws://backend:8000
# Production: wss://api.yourdomain.com
