# =============================================================================
# TestAI Platform - Frontend (Next.js) Environment Variables
# =============================================================================

# Python Harness Backend URL
# Local dev: http://localhost:8000
# Docker: http://backend:8000 (set in docker-compose.yml, override here if needed)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

# OpenCode API Key (for direct LLM calls from server-side API routes)
OPENAI_API_KEY=sk-your-opencode-api-key-here

# OpenCode Base URL
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1

# Default LLM model
NEXT_PUBLIC_DEFAULT_MODEL=deepseek-v4-flash
DEFAULT_MODEL=deepseek-v4-flash
