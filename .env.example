# =============================================================================
# TestAI Harness - Environment Configuration
# =============================================================================
# Copy to .env and fill in your values.
#
# NOTE: LLM provider API keys, endpoints, and models are now configured
# from the Settings → Backend Providers page in the UI.
# Environment variables below are only needed for the server itself.

# ==================== Server ====================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# TestAI Platform - Frontend (Next.js) Environment Variables
# =============================================================================

# Python Harness Backend URL
# The new Python agent harness runs on port 8000 by default
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

# OpenCode API Key (for direct LLM calls from server-side API routes)

# OpenCode Base URL
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1
DATABASE_URL=postgresql://testai:testai@127.0.0.1:5433/testai
# Default LLM model
NEXT_PUBLIC_DEFAULT_MODEL=deepseek-v4-flash
DEFAULT_MODEL=deepseek-v4-flash
