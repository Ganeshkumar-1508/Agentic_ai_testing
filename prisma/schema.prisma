// This is your Prisma schema file for TestAI Platform
// AI-Powered Testing Automation Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  role      String   @default("user") // admin, user, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projects    Project[]
  testRuns    TestRun[]
  activities  Activity[]
}

// Project Management
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active") // active, archived, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  requirements  Requirement[]
  testCases     TestCase[]
  testRuns      TestRun[]
  agents        AgentRun[]
}

// Requirements Management
model Requirement {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   @default("user_story") // user_story, acceptance_criteria, edge_case, api_spec
  priority    String   @default("medium") // low, medium, high, critical
  status      String   @default("pending") // pending, processing, completed
  source      String?  // text, file_upload, api_import
  fileName    String?  // Original file name if uploaded
  rawContent  String?  // Original content before parsing
  
  // Parsed data
  acceptanceCriteria String? // JSON array
  edgeCases          String? // JSON array
  testScenarios      String? // JSON array
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  testCases TestCase[]
}

// Test Cases
model TestCase {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // api, ui, unit, performance, security
  status      String   @default("pending") // pending, passed, failed, running
  priority    String   @default("medium")
  
  // Test details
  steps        String? // JSON array of test steps
  expected     String? // Expected results
  testData     String? // JSON test data
  
  // Generated code
  code         String? // Generated test code
  codeLanguage String? // python, typescript, javascript
  
  // Execution results
  duration     Int?    // Duration in milliseconds
  errorMessage String?
  stackTrace   String?
  
  // MCP Tools used
  mcpTools     String? // JSON array of MCP tool names
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  executedAt DateTime?
  
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id])
  requirementId String?
  requirement   Requirement? @relation(fields: [requirementId], references: [id])
  agentId       String?
  agent         AgentRun?   @relation(fields: [agentId], references: [id])
  testRuns      TestRunCase[]
}

// Agent Runs - Track agent execution
model AgentRun {
  id          String   @id @default(cuid())
  name        String   // Agent name (RequirementsAnalyst, TestCodeGenerator, etc.)
  type        String   // analyst, generator, executor, reporter
  status      String   @default("pending") // pending, running, completed, failed
  model       String   @default("meta/llama-3.1-405b-instruct")
  provider    String   @default("nvidia-nim")
  
  // Input/Output
  input       String?  // JSON input data
  output      String?  // JSON output data
  
  // Execution details
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?     // Duration in milliseconds
  tokensUsed  Int?
  
  // Progress tracking
  progress    Int      @default(0) // 0-100
  currentTask String?
  
  // Error handling
  errorMessage String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  testCases TestCase[]
  logs      AgentLog[]
}

// Agent Logs - Detailed execution logs
model AgentLog {
  id        String   @id @default(cuid())
  level     String   // info, success, warning, error
  message   String
  metadata  String?  // JSON additional data
  timestamp DateTime @default(now())
  
  agentId String
  agent   AgentRun @relation(fields: [agentId], references: [id])
}

// Test Runs - Execution sessions
model TestRun {
  id          String   @id @default(cuid())
  name        String?
  status      String   @default("pending") // pending, running, completed, cancelled
  environment String?  // dev, staging, production
  
  // Statistics
  totalTests   Int     @default(0)
  passedTests  Int     @default(0)
  failedTests  Int     @default(0)
  skippedTests Int     @default(0)
  
  // Timing
  startedAt   DateTime?
  completedAt DateTime?
  duration    Int?     // Total duration in milliseconds
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  testCases TestRunCase[]
}

// Test Run Cases - Individual test execution in a run
model TestRunCase {
  id        String   @id @default(cuid())
  status    String   // pending, passed, failed, skipped
  duration  Int?
  error     String?
  
  testRunId String
  testRun   TestRun @relation(fields: [testRunId], references: [id])
  testCaseId String
  testCase  TestCase @relation(fields: [testCaseId], references: [id])
  
  startedAt   DateTime?
  completedAt DateTime?
}

// Activity Log - User/Agent activities
model Activity {
  id        String   @id @default(cuid())
  type      String   // test_created, test_run, agent_started, etc.
  action    String
  details   String?  // JSON additional details
  createdAt DateTime @default(now())
  
  userId String?
  user   User?     @relation(fields: [userId], references: [id])
}

// MCP Tool Registry
model MCPTool {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  category    String   // filesystem, browser, database, api, etc.
  enabled     Boolean  @default(true)
  config      String?  // JSON configuration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Settings
model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
