# =============================================================================
# TestAI Platform - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp backend/.env.example backend/.env
#
# Required:  SECRET_KEY, DATABASE_URL
# Optional:  API keys for LLM providers you want to use
# =============================================================================

# ==================== Application ====================
ENVIRONMENT=development           # development | staging | production
DEBUG=true                        # true | false
SECRET_KEY=change-me-to-a-random-secret-key  # REQUIRED: Generate via: openssl rand -hex 32

# ==================== Database (PostgreSQL) ====================
# Connection string format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/testai

# Docker Compose uses these to spin up the PostgreSQL container:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres        # CHANGE in production
POSTGRES_DB=testai

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0
# Docker users: redis://redis:6379/0

# ==================== LLM Providers ====================
# At least ONE API key is required for the platform to function.
# Uncomment and set the keys for the providers you want to use.

# OpenAI (GPT-4, GPT-4o, GPT-4o-mini, GPT-3.5-turbo)
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic (Claude 3.5 Sonnet, Claude 3 Opus, Claude 3 Haiku)
# Get key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# NVIDIA NIM (Llama-3.1-Nemotron, Mistral-NeMo, etc.)
# Get key at: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-...

# Groq (Fast inference on open-source models)
# Get key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk-...

# Cohere (Command-R, Command-R+)
# Get key at: https://dashboard.cohere.com/api-keys
# COHERE_API_KEY=...

# OpenRouter (Multi-model gateway)
# Get key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# XAI (Grok)
# Get key at: https://console.x.ai/
# XAI_API_KEY=xai-...

# Azure OpenAI (Enterprise)
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-15-preview

# ==================== Default Model Settings ====================
DEFAULT_MODEL=gpt-4o
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=16000

# ==================== Swarms (Multi-Agent) ====================
SWARM_MAX_LOOPS=3
SWARM_RETRY_ATTEMPTS=3
AGENT_TIMEOUT_SECONDS=300

# ==================== Rate Limiting ====================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]
