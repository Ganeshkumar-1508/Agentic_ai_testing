# TestAI Platform - Environment Configuration
# Copy this file to .env and fill in your values

# ============== Application ==============
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=c5130d5897a6e17007445ff87a3a1b557a0bfd7c4b5749b974637d1073e086512839e929c7d1ebfd34d57307435c5ee9

# # ============== Database ==============
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/testai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=testai

# # ============== Redis ==============
# REDIS_URL=redis://localhost:6379/0

# # ============== LLM Providers ==============
# # Uncomment and add your API keys for the providers you want to use

# # OpenAI (GPT-4, GPT-4o, GPT-3.5)
# OPENAI_API_KEY=sk-xxx

# # Anthropic (Claude 3.5 Sonnet, Claude 3 Opus)
# ANTHROPIC_API_KEY=sk-ant-xxx

# # NVIDIA NIM (Llama, Nemotron models)
NVIDIA_API_KEY=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

# # Groq (Fast inference)
# GROQ_API_KEY=gsk-xxx

# # Cohere (Command models)
# COHERE_API_KEY=xxx

# # OpenRouter (Multiple models)
# OPENROUTER_API_KEY=sk-or-xxx

# # XAI (Grok)
# XAI_API_KEY=xai-xxx

# # Azure OpenAI
# AZURE_API_KEY=xxx
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-15-preview

# ============== Default Model Settings ==============
DEFAULT_MODEL=qwen/qwen3-next-80b-a3b-instruct

DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=16000

# ============== Swarms Settings ==============
SWARM_MAX_LOOPS=3
SWARM_RETRY_ATTEMPTS=3
AGENT_TIMEOUT_SECONDS=300

# ============== Rate Limiting ==============
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============== CORS ==============
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]
