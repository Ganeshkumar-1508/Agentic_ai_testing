from __future__ import annotations

import asyncio
import json
import logging
import os
import threading
import time
import uuid
from contextlib import asynccontextmanager
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, AsyncIterator, Callable

logger = logging.getLogger(__name__)

_MCP_AVAILABLE = True
try:
    from mcp.client.session import ClientSession
    from mcp.client.sse import sse_client
    from mcp.client.stdio import stdio_client
    from mcp.types import CallToolResult
except ImportError:
    _MCP_AVAILABLE = False

_OAUTH_AVAILABLE = False
try:
    from mcp.client.auth import OAuthClientProvider
    _OAUTH_AVAILABLE = True
except ImportError:
    pass


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

RECONNECT_BASE_DELAY = 1.0
RECONNECT_MAX_DELAY = 30.0
HEALTH_CHECK_INTERVAL = 30.0
TOOL_REFRESH_INTERVAL = 120.0
TOKEN_DIR = Path.home() / ".testai" / "mcp-tokens"


# ---------------------------------------------------------------------------
# Data types
# ---------------------------------------------------------------------------


@dataclass
class MCPToolDef:
    name: str
    description: str | None
    input_schema: dict[str, Any]
    server_id: str


@dataclass
class MCPResourceDef:
    uri: str
    name: str
    description: str | None = None
    mime_type: str | None = None
    server_id: str = ""


@dataclass
class MCPPromptDef:
    name: str
    description: str | None = None
    arguments: list[dict[str, Any]] = field(default_factory=list)
    server_id: str = ""


@dataclass
class MCPServerInfo:
    id: str
    name: str
    url: str
    transport_type: str
    connected: bool = False
    error: str | None = None
    tools: list[MCPToolDef] = field(default_factory=list)
    resources: list[MCPResourceDef] = field(default_factory=list)
    prompts: list[MCPPromptDef] = field(default_factory=list)
    supports_resources: bool = False
    supports_prompts: bool = False


# ---------------------------------------------------------------------------
# Background MCP event loop (single thread, one loop for all connections)
# ---------------------------------------------------------------------------

_mcp_loop: asyncio.AbstractEventLoop | None = None
_mcp_thread: threading.Thread | None = None
_mcp_servers: dict[str, MCPServerInfo] = {}
_mcp_sessions: dict[str, ClientSession] = {}
_mcp_lock = threading.Lock()


def _ensure_loop() -> asyncio.AbstractEventLoop:
    global _mcp_loop, _mcp_thread
    with _mcp_lock:
        if _mcp_loop is None or _mcp_loop.is_closed():
            _mcp_loop = asyncio.new_event_loop()
            _mcp_thread = threading.Thread(target=_mcp_loop.run_forever, daemon=True)
            _mcp_thread.start()
        return _mcp_loop


def _run_coro(coro, timeout: float = 30) -> Any:
    """Schedule a coroutine on the MCP loop and wait for the result."""
    loop = _ensure_loop()
    future = asyncio.run_coroutine_threadsafe(coro, loop)
    return future.result(timeout=timeout)


async def _run_coro_async(coro, timeout: float = 30) -> Any:
    """Run a coroutine on the MCP loop from an async context."""
    loop = _ensure_loop()
    future = asyncio.run_coroutine_threadsafe(coro, loop)
    return await asyncio.wrap_future(future)


# ---------------------------------------------------------------------------
# Schema normalization (mirrors Hermes _normalize_mcp_input_schema)
# ---------------------------------------------------------------------------


def _normalize_schema(schema: dict | None) -> dict:
    if not schema:
        return {"type": "object", "properties": {}}
    
    def _rewrite_refs(node):
        if isinstance(node, dict):
            result = {}
            for k, v in node.items():
                out_k = "$defs" if k == "definitions" else k
                result[out_k] = _rewrite_refs(v)
            ref = result.get("$ref")
            if isinstance(ref, str) and ref.startswith("#/definitions/"):
                result["$ref"] = "#/$defs/" + ref[len("#/definitions/"):]
            return result
        if isinstance(node, list):
            return [_rewrite_refs(i) for i in node]
        return node

    def _ensure_object(node):
        if isinstance(node, list):
            return [_ensure_object(i) for i in node]
        if not isinstance(node, dict):
            return node
        repaired = {k: _ensure_object(v) for k, v in node.items()}
        if not repaired.get("type") and ("properties" in repaired or "required" in repaired):
            repaired["type"] = "object"
        if repaired.get("type") == "object":
            props = repaired.get("properties")
            if not isinstance(props, dict):
                repaired["properties"] = {}
            required = repaired.get("required")
            if isinstance(required, list):
                props = repaired.get("properties") or {}
                valid = [r for r in required if isinstance(r, str) and r in props]
                repaired["required"] = valid if valid else repaired.pop("required", None)
        return repaired

    return _ensure_object(_rewrite_refs(schema))


# ---------------------------------------------------------------------------
# MCP Client
# ---------------------------------------------------------------------------


class MCPClient:
    """MCP client using the native mcp SDK with background loop."""

    def __init__(self):
        self._servers: dict[str, MCPServerInfo] = {}
        self._sessions: dict[str, ClientSession] = {}
        self._tool_to_server: dict[str, str] = {}
        self._running = False
        self._cleanup_task: asyncio.Task | None = None

    async def initialize(self, servers: list[dict[str, Any]]) -> None:
        if not _MCP_AVAILABLE:
            logger.warning("MCP SDK not installed. Run: pip install mcp")
            return
        self._running = True
        loop = _ensure_loop()

        for srv in servers:
            if not srv.get("enabled", True):
                continue
            srv_id = srv.get("id", srv.get("url", ""))
            url = srv.get("url", "")
            transport_type = "sse" if url.startswith("http") else "stdio"

            info = MCPServerInfo(
                id=srv_id,
                name=srv.get("name", url),
                url=url,
                transport_type=transport_type,
            )
            self._servers[srv_id] = info

        # Connect all in parallel
        await asyncio.gather(
            *(self._connect_one(sid) for sid in self._servers),
            return_exceptions=True,
        )
        self._rebuild_index()

    async def _connect_one(self, server_id: str) -> None:
        info = self._servers.get(server_id)
        if not info:
            return

        for attempt in range(10):
            if not self._running:
                return
            try:
                if info.transport_type == "sse":
                    await self._connect_sse(info)
                else:
                    await self._connect_stdio(info)

                if info.connected:
                    logger.info("MCP connected: %s (%d tools)", info.name, len(info.tools))
                    return
            except Exception as e:
                delay = min(RECONNECT_BASE_DELAY * (2 ** attempt), RECONNECT_MAX_DELAY)
                logger.warning("MCP %s connect failed (attempt %d): %s", info.name, attempt, e)
                info.error = str(e)
                await asyncio.sleep(delay)

    async def _connect_sse(self, info: MCPServerInfo) -> None:
        async with sse_client(url=info.url) as (read, write):
            async with ClientSession(read, write) as session:
                await session.initialize()
                self._sessions[info.id] = session
                await self._populate_server_info(info, session)

    async def _connect_stdio(self, info: MCPServerInfo) -> None:
        import shlex
        cmd_parts = shlex.split(info.url)
        async with stdio_client(cmd_parts) as (read, write):
            async with ClientSession(read, write) as session:
                await session.initialize()
                self._sessions[info.id] = session
                await self._populate_server_info(info, session)

    async def _populate_server_info(self, info: MCPServerInfo, session: ClientSession) -> None:
        # Tools
        tools_result = await session.list_tools()
        info.tools = [
            MCPToolDef(name=t.name, description=t.description, input_schema=_normalize_schema(t.inputSchema), server_id=info.id)
            for t in tools_result.tools
        ]

        # Resources (server capability check)
        try:
            resources_result = await session.list_resources()
            info.resources = [
                MCPResourceDef(uri=str(r.uri), name=r.name, description=r.description, mime_type=r.mimeType, server_id=info.id)
                for r in resources_result.resources
            ]
            info.supports_resources = True
        except Exception:
            info.supports_resources = False

        # Prompts (server capability check)
        try:
            prompts_result = await session.list_prompts()
            info.prompts = [
                MCPPromptDef(name=p.name, description=p.description, arguments=[{"name": a.name, "description": a.description, "required": a.required} for a in (p.arguments or [])], server_id=info.id)
                for p in prompts_result.prompts
            ]
            info.supports_prompts = True
        except Exception:
            info.supports_prompts = False

        info.connected = True
        info.error = None

    def _rebuild_index(self) -> None:
        self._tool_to_server.clear()
        for sid, info in self._servers.items():
            for tool in info.tools:
                self._tool_to_server[tool.name] = sid

    def get_openai_tools(self) -> list[dict[str, Any]]:
        result = []
        for info in self._servers.values():
            if not info.connected:
                continue
            for tool in info.tools:
                result.append({
                    "type": "function",
                    "function": {
                        "name": tool.name,
                        "description": tool.description or f"MCP tool from {info.name}",
                        "parameters": tool.input_schema,
                    },
                })
        return result

    async def call_tool(self, tool_name: str, args: dict[str, Any]) -> str:
        server_id = self._tool_to_server.get(tool_name)
        if not server_id:
            raise RuntimeError(f"No MCP server found for tool: {tool_name}")
        session = self._sessions.get(server_id)
        if not session:
            raise RuntimeError(f"MCP server not connected: {server_id}")

        result = await session.call_tool(tool_name, arguments=args)
        parts = []
        for block in (result.content or []):
            if hasattr(block, "text") and block.text:
                parts.append(block.text)
        return "\n".join(parts)

    def has_tools(self) -> bool:
        return len(self.get_openai_tools()) > 0

    def get_connections(self) -> list[MCPServerInfo]:
        return list(self._servers.values())

    async def disconnect_all(self) -> None:
        self._running = False
        for session in self._sessions.values():
            try:
                await session.close()
            except Exception:
                pass
        self._servers.clear()
        self._sessions.clear()
        self._tool_to_server.clear()


# ---------------------------------------------------------------------------
# OAuth support
# ---------------------------------------------------------------------------


async def start_oauth_flow(
    server_name: str,
    server_url: str,
    oauth_config: dict | None = None,
    token_dir: str | None = None,
) -> dict[str, Any]:
    """Start the OAuth authorization flow for an MCP server.
    
    Returns the authorization URL that the user needs to open in a browser.
    After authorization, the callback endpoint completes the flow.
    """
    if not _OAUTH_AVAILABLE:
        return {"error": "MCP OAuth not available. Install: pip install 'mcp>=1.26.0'"}

    from mcp.client.auth import OAuthClientProvider
    from mcp.shared.auth import OAuthToken, OAuthClientInformationFull, OAuthMetadata, OAuthClientMetadata
    from pydantic import AnyUrl

    tokens_path = Path(token_dir or TOKEN_DIR)
    tokens_path.mkdir(parents=True, exist_ok=True)
    state = str(uuid.uuid4())
    auth_state = {
        "server_name": server_name,
        "server_url": server_url,
        "state": state,
        "created_at": time.time(),
    }
    state_path = tokens_path / f"{server_name}_pending.json"
    state_path.write_text(json.dumps(auth_state))

    meta_path = tokens_path / f"{server_name}_meta.json"
    cfg = dict(oauth_config or {})
    port = cfg.get("redirect_port", 0)
    if not port:
        import socket
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.bind(("127.0.0.1", 0))
            port = s.getsockname()[1]
    
    redirect_uri = f"http://127.0.0.1:{port}/callback"
    client_meta = OAuthClientMetadata(
        client_name=cfg.get("client_name", "TestAI"),
        redirect_uris=[AnyUrl(redirect_uri)],
        grant_types=["authorization_code", "refresh_token"],
        response_types=["code"],
        token_endpoint_auth_method="none",
    )

    discovery_url = f"{server_url.rstrip('/')}/well-known/oauth-authorization-server"
    import httpx
    async with httpx.AsyncClient() as client:
        resp = await client.get(discovery_url)
        resp.raise_for_status()
        oauth_meta = OAuthMetadata(**resp.json())
    
    meta_path.write_text(json.dumps(oauth_meta.model_dump(mode="json", exclude_none=True)))

    client_id = cfg.get("client_id", "testai-client")
    auth_url = f"{oauth_meta.authorization_endpoint}?response_type=code&client_id={client_id}&redirect_uri={redirect_uri}&state={state}&scope={cfg.get('scope', 'openid profile email')}"

    return {
        "auth_url": auth_url,
        "state": state,
        "redirect_uri": redirect_uri,
        "port": port,
    }


async def complete_oauth_flow(
    server_name: str,
    auth_code: str,
    state: str,
    token_dir: str | None = None,
) -> dict[str, Any]:
    """Complete the OAuth flow by exchanging the authorization code for tokens."""
    tokens_path = Path(token_dir or TOKEN_DIR)
    state_path = tokens_path / f"{server_name}_pending.json"
    if not state_path.exists():
        return {"error": "No pending OAuth flow found"}

    pending = json.loads(state_path.read_text())
    if pending.get("state") != state:
        return {"error": "State mismatch"}
    
    meta_path = tokens_path / f"{server_name}_meta.json"
    oauth_meta = OAuthMetadata(**json.loads(meta_path.read_text()))
    
    import httpx
    token_data = {
        "grant_type": "authorization_code",
        "code": auth_code,
        "redirect_uri": pending.get("redirect_uri", ""),
        "client_id": "testai-client",
    }
    async with httpx.AsyncClient() as client:
        resp = await client.post(oauth_meta.token_endpoint, data=token_data)
        resp.raise_for_status()
        token_json = resp.json()

    token_path = tokens_path / f"{server_name}.json"
    token_path.write_text(json.dumps(token_json))
    state_path.unlink(missing_ok=True)

    return {"status": "ok", "server_name": server_name}
